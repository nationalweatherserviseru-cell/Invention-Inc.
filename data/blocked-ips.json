import fs from 'fs';
import path from 'path';

export default function handler(req, res) {
    const clientIP = req.headers['x-forwarded-for'] || req.socket.remoteAddress;
    
    const blockedIPsPath = path.join(process.cwd(), 'data', 'blocked-ips.json');
    const blockedIPs = JSON.parse(fs.readFileSync(blockedIPsPath, 'utf8'));
    
    const isBlocked = blockedIPs.includes(clientIP);
    
    res.status(200).json({ blocked: isBlocked });
}
